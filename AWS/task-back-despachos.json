{
  "family": "task-back-despachos",
  "taskRoleArn": "arn:aws:iam::020935060597:role/LabRole",
  "executionRoleArn": "arn:aws:iam::020935060597:role/LabRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "back-despacho",
      "image": "020935060597.dkr.ecr.us-east-1.amazonaws.com/backdespachos-:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/task-back-despachos",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024"
}